    "credential_patterns": {
      "github_pat": "ghp_[A-Za-z0-9]{36,}",
      "aws_access_key": "AKIA[0-9A-Z]{16}",
      "api_key_generic": "sk-[A-Za-z0-9]{20,}",
      "private_key_pem": "-----BEGIN.*PRIVATE KEY-----",
      "database_url": "postgres://.*:.*@.*",
      "aws_secret": "aws_secret_access_key"
    }
