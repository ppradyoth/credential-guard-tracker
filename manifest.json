  "metrics": {
    "primary_metrics": [
      {
        "name": "pr_status",
        "description": "Open/Closed/Merged status of #62099",
        "source": "GitHub REST API",
        "update_frequency": "hourly"
      },
      {
        "name": "pr_engagement",
        "description": "Comments, reactions, reviews on PR",
        "source": "GitHub REST API",
        "update_frequency": "hourly"
      },
      {
        "name": "plugin_stars",
        "description": "Repository stars (proxy for adoption)",
        "source": "GitHub REST API",
        "update_frequency": "daily"
      },
      {
        "name": "citations",
        "description": "Mentions in Big Model Radar, GitHub, Twitter",
        "source": "Big Model Radar API, GitHub Search, Twitter API",
        "update_frequency": "daily"
      }
    ],
    "ecosystem_metrics": [
      {
        "name": "related_security_prs",
        "description": "Similar security initiatives in other AI CLI tools",
        "source": "GitHub Search across tracked repos",
        "update_frequency": "daily"
      },
      {
        "name": "credential_issues",
        "description": "Issues related to hardcoded secrets, credentials",
        "source": "GitHub Search",
        "update_frequency": "daily"
      },
      {
        "name": "ecosystem_trend",
        "description": "Security-focused features trending in AI CLI tools",
        "source": "GitHub trending, Big Model Radar",
        "update_frequency": "weekly"
      }
    ]
  },
  "report_schedule": {
    "daily": {
      "time": "08:00 UTC",
      "label": "daily-report",
      "retention_days": 30,
      "description": "24-hour metric snapshots and highlights"
    },
    "weekly": {
      "day": "Monday",
      "time": "09:00 UTC",
      "label": "weekly-report",
      "retention_days": 90,
      "description": "7-day trend analysis and insights"
    },
    "monthly": {
      "day": "1st",
      "time": "10:00 UTC",
      "label": "monthly-report",
      "retention_days": 365,
      "description": "30-day deep dive and ecosystem comparison"
    }
  },
  "search_keywords": [
    "credential",
    "secret",
    "api_key",
    "apikey",
    "hardcoded",
    "hardcode",
    "token",
    "password",
    "authentication",
    "security"
  ],
  "github_actions": {
    "permissions": [
      "contents:read",
      "issues:write",
      "pull-requests:read"
    ],
    "secrets_required": [
      "GITHUB_TOKEN"
    ]
